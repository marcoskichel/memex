{
  "name": "@neurome/root",
  "version": "1.0.0",
  "private": true,
  "description": "Memex monorepo",
  "main": "index.js",
  "scripts": {
    "build": "turbo build",
    "dev:nuclei": "turbo run dev --concurrency=20",
    "dev:cortex": "turbo run dev:run --filter=@neurome/cortex",
    "dev:tui": "pnpm --filter=@neurome/neurome-tui run dev:run",
    "test": "turbo test",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "typecheck": "turbo typecheck",
    "check": "turbo run lint typecheck test --continue=never",
    "check:fix": "turbo run lint:fix typecheck test --continue=never",
    "prepare": "husky",
    "db:seed": "tsx --env-file=synapses/cortex/.env.local scripts/seed-dev-db.mts",
    "e2e": "turbo run e2e"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yaml,yml}": "prettier --write"
  },
  "keywords": [],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@exodus/openspec": "^1.2.6",
    "@neurome/ltm": "workspace:*",
    "tsx": "^4.19.3",
    "@neurome/eslint-config": "workspace:*",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3"
  }
}
