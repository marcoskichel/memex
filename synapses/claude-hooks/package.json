{
  "name": "@neurokit/claude-hooks",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "post-tool-use": "./dist/bin/post-tool-use.js",
    "pre-tool-use": "./dist/bin/pre-tool-use.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "check:fix": "pnpm run lint:fix && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@neurokit/stm": "workspace:*",
    "neverthrow": "^8.1.1",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@neurokit/eslint-config": "workspace:*",
    "@neurokit/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
