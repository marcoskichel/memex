{
  "name": "@neurome/neurome-tui",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "neurome-tui": "./dist/bin/neurome-tui.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dev:run": "node --env-file=.env.local --watch ./dist/bin/neurome-tui.js",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "check:fix": "pnpm run lint:fix && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@neurome/cortex-ipc": "workspace:*",
    "@neurome/memory": "workspace:*",
    "ink": "^5.2.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@neurome/eslint-config": "workspace:*",
    "@neurome/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.21",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
