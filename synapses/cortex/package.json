{
  "name": "@neurome/cortex",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "cortex": "./dist/bin/cortex.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dev:run": "node --env-file=.env.local --watch ./dist/bin/cortex.js",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "check:fix": "pnpm run lint:fix && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@neurome/cortex-ipc": "workspace:*",
    "@neurome/llm": "workspace:*",
    "@neurome/ltm": "workspace:*",
    "@neurome/memory": "workspace:*",
    "@neurome/stm": "workspace:*"
  },
  "devDependencies": {
    "@neurome/eslint-config": "workspace:*",
    "@neurome/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^3.1.1"
  }
}
