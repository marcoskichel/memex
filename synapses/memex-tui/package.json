{
  "name": "@memex/memex-tui",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "memex-tui": "./dist/bin/memex-tui.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "check:fix": "pnpm run lint:fix && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@memex/cortex": "workspace:*",
    "@memex/memory": "workspace:*",
    "ink": "^5.2.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@memex/eslint-config": "workspace:*",
    "@memex/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.21",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
