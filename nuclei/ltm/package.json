{
  "name": "@neurome/ltm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "check:fix": "pnpm run lint:fix && pnpm run typecheck && pnpm run test",
    "e2e": "dotenv -e .env.e2e -- tsx scripts/e2e.ts"
  },
  "dependencies": {
    "@neurome/entorhinal": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "neverthrow": "^8.2.0",
    "openai": "^6.33.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@neurome/eslint-config": "workspace:*",
    "@neurome/typescript-config": "workspace:*",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
