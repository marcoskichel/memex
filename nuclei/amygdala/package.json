{
  "name": "@neurome/amygdala",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "check:fix": "pnpm run lint:fix && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@neurome/llm": "workspace:*",
    "@neurome/ltm": "workspace:*",
    "@neurome/stm": "workspace:*",
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "@neurome/eslint-config": "workspace:*",
    "@neurome/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
