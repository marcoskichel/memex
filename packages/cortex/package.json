{
  "name": "@neurokit/cortex",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "cortex": "./dist/bin/cortex.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "check:fix": "pnpm run lint:fix && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@neurokit/llm": "workspace:*",
    "@neurokit/memory": "workspace:*",
    "@neurokit/stm": "workspace:*"
  },
  "devDependencies": {
    "@neurokit/eslint-config": "workspace:*",
    "@neurokit/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
